<%# ===== SHOW PAGE — displays one specific list and the movies in it ===== %>
<%# @list is set by the before_action :set_list in the controller.           %>
<%# @list.movies works because List has_many :movies, through: :bookmarks.   %>

<div class="show-page">

  <%# --- Cover banner: left = title/count/back, right = add movie form --- %>
  <div class="cover mb-4">
    <div class="container h-100 d-flex align-items-center justify-content-between gap-4">

      <%# Left — list title, movie count, back button %>
      <div class="show-cover__left">
        <h1 class="show-cover__title"><%= @list.name %></h1>
        <p class="lead mb-3"><%= @list.movies.count %> <%= "movie".pluralize(@list.movies.count) %></p>
        <%= link_to "← Back to all lists", lists_path, class: "btn btn-create-list btn-sm" %>
      </div>

      <%# Right — add movie form %>
      <div class="add-movie-panel">
        <%= simple_form_for @bookmark, url: bookmarks_path do |f| %>
          <%= f.input :movie_id, label: false, as: :select,
                      collection: Movie.order(:title).map { |m| [m.title, m.id] },
                      include_blank: "Pick a movie" %>
          <%= f.input :comment, label: false,
                      placeholder: "Add a comment",
                      required: false %>
          <%= f.hidden_field :list_id, value: @list.id %>
          <div class="d-grid">
            <button type="submit" class="btn btn-create-list">Add to List</button>
          </div>
        <% end %>
      </div>

    </div>
  </div>

  <%# --- Full-width movie grid --- %>
  <div class="container py-4">
    <% if @list.movies.any? %>
      <div class="row">
        <% @list.movies.each do |movie| %>
          <div class="col-12 col-sm-6 col-md-4 col-lg-3 mb-4">
            <div class="card movie-card h-100">

              <% if movie.poster_url.present? %>
                <img src="<%= movie.poster_url %>" class="card-img-top"
                     alt="<%= movie.title %> poster" style="object-fit: cover; height: 260px;">
              <% else %>
                <div class="d-flex align-items-center justify-content-center"
                     style="height: 260px; background-color: #1a0f08;">
                  <i class="fa-solid fa-film" style="font-size: 3rem; color: rgba(245,236,215,0.3);"></i>
                </div>
              <% end %>

              <div class="card-body d-flex flex-column">
                <h6 class="card-title mb-1"><%= movie.title %></h6>
                <span class="badge mb-2">
                  <i class="fa-solid fa-star"></i> <%= movie.rating.round(1) %>
                </span>
                <p class="card-text small flex-grow-1">
                  <%= truncate(movie.overview, length: 80) %>
                </p>
              </div>

            </div>
          </div>
        <% end %>
      </div>

    <% else %>
      <div class="text-center py-5" style="color: rgba(245,236,215,0.5);">
        <i class="fa-solid fa-film mb-3" style="font-size: 3rem;"></i>
        <p>No movies in this list yet.</p>
      </div>
    <% end %>
  </div><%# end .container %>

</div><%# end .show-page %>
