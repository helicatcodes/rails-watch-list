<div class="form-page d-flex align-items-center justify-content-center">
  <div class="form-card p-4 shadow">

    <div class="text-center mb-4">
      <i class="fa-solid fa-film movie-icon"></i>
      <h2>Create a Movie List</h2>
      <p class="text-muted">Start organizing your favorite movies</p>
    </div>

    <%= simple_form_for @list do |f| %>
      <%= f.input :name, placeholder: "e.g. Sunday Night Movies" %>

      <div class="d-grid mt-3">
        <%= f.submit "Create List", class: "btn btn-primary" %>
      </div>
    <% end %>

  </div>
</div>

<div class="text-center mt-3">
  <%= link_to "← Back to lists", lists_path, class: "text-muted" %>
</div>
